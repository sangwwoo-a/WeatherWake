<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_deep">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_deep"
        app:elevation="0dp">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarSnow"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/toolbar_title_weather"
            app:subtitle="@string/toolbar_subtitle_snow"
            app:titleTextColor="@color/text_primary"
            app:subtitleTextColor="@color/text_secondary"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/text_primary"/>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- 본문 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="14dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_how_early_wake"
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="5dp"/>

        <Spinner
            android:id="@+id/spinnerSnowAdvance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/outline" android:layout_marginVertical="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_snow_threshold_question"
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="10dp"/>

        <!-- 아주민감 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSnowVerySensitive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/outline"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="10dp" android:gravity="center_vertical">
                <RadioButton android:id="@+id/radioSnowVerySensitive"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp" android:clickable="false" android:focusable="false"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/sensitivity_very_label"
                            android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/label_threshold_snow_0_5cm" android:textSize="12sp" android:textColor="@color/text_hint"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/snow_desc_very"
                        android:textSize="13sp" android:textColor="@color/text_secondary" android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 민감 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSnowSensitive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/outline"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="10dp" android:gravity="center_vertical">
                <RadioButton android:id="@+id/radioSnowSensitive"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp" android:clickable="false" android:focusable="false"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/sensitivity_sensitive_label"
                            android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/label_threshold_snow_1cm" android:textSize="12sp" android:textColor="@color/text_hint"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/snow_desc_sensitive"
                        android:textSize="13sp" android:textColor="@color/text_secondary" android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 보통 (권장) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSnowNormal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/primary_blue"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="10dp" android:gravity="center_vertical">
                <RadioButton android:id="@+id/radioSnowNormal"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp" android:checked="true"
                    android:clickable="false" android:focusable="false"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/sensitivity_normal_recommended"
                            android:textSize="15sp" android:textStyle="bold" android:textColor="@color/primary_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/label_threshold_snow_1_3cm" android:textSize="12sp" android:textColor="@color/text_hint"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/snow_desc_normal"
                        android:textSize="13sp" android:textColor="@color/text_secondary" android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 둔감 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSnowDull"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bg_card"
            app:strokeWidth="1.5dp"
            app:strokeColor="@color/outline"
            android:clickable="true"
            android:focusable="true">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="10dp" android:gravity="center_vertical">
                <RadioButton android:id="@+id/radioSnowDull"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp" android:clickable="false" android:focusable="false"/>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="@string/sensitivity_low_label"
                            android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/label_threshold_snow_3cm" android:textSize="12sp" android:textColor="@color/text_hint"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/snow_desc_low"
                        android:textSize="13sp" android:textColor="@color/text_secondary" android:layout_marginTop="3dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/label_owm_weather_info"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:lineSpacingExtra="2dp"/>

    </LinearLayout>

    <!-- 하단 버튼 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_deep"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSnowBack"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
            android:text="@string/action_back" android:layout_marginEnd="8dp"
            app:strokeColor="@color/outline" android:textColor="@color/text_secondary"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSnowNext"
            android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="2"
            android:text="@string/action_sound_setup"
            app:backgroundTint="@color/primary_blue" android:textColor="@color/bg_deep"/>
    </LinearLayout>

</LinearLayout>
