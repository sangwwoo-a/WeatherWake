<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_alarm_ring">

    <!-- 현재 시각 (초대형) -->
    <TextView android:id="@+id/tvCurrentTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="88sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="-0.04"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvReason"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38"/>

    <!-- 날씨로 앞당겨진 이유 배지 -->
    <TextView android:id="@+id/tvReason"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_weather_badge"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp"
        android:gravity="center"
        android:textSize="14sp"
        android:textColor="@color/cyan_weather"
        android:textStyle="bold"
        android:visibility="gone"
        android:layout_marginHorizontal="32dp"
        app:layout_constraintBottom_toTopOf="@id/btnSnooze"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="40dp"/>

    <!-- 스누즈 버튼 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSnooze"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/action_snooze_5min"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="12dp"
        app:strokeColor="@color/outline"
        app:layout_constraintBottom_toTopOf="@id/btnDismiss"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 알람 끄기 버튼 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDismiss"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="@string/action_dismiss_alarm"
        android:textColor="@color/bg_deep"
        android:textSize="17sp"
        android:textStyle="bold"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="60dp"
        app:backgroundTint="@color/primary_blue"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
