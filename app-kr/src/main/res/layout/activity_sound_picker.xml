<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep">

    <!-- 상단 앱바 (툴바 + 탭) -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_deep"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/toolbar_title_sound_picker"
            app:subtitle="@string/toolbar_subtitle_sound_picker"
            app:titleTextColor="@color/text_primary"
            app:subtitleTextColor="@color/text_secondary"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/text_primary"/>

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_deep"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabTextColor="@color/text_secondary"
            app:tabSelectedTextColor="@color/primary_blue"
            app:tabIndicatorColor="@color/primary_blue"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- 음원 목록 (앱바 아래 ~ 하단 바 위) -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        app:layout_anchorGravity="top"/>

    <!-- 하단 고정 확인 버튼 (네비게이션 바 위에 떠있음) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:text="@string/action_done"
        android:padding="14dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
