    <string name="message_overlay_permission_title">🔔 Alarm Display Permission Required</string>
    <string name="message_overlay_permission_body">To show alarms even when the screen is off,\nwe need the \'Display over other apps\' permission.\n\nWhen the settings screen opens, please allow WeatherWake.</string>
