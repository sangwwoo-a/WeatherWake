    <string name="message_full_screen_permission_title">⏰ Lock Screen Alarm Permission Required</string>
    <string name="message_full_screen_permission_body">To display the alarm screen full-screen when the screen is off,\nwe need permission.\n\nWhen the settings screen opens, find \'WeatherWake\'\nand allow \'Display full screen\'.</string>
    <string name="message_exact_alarm_permission_title">Alarm Permission Required</string>
    <string name="message_exact_alarm_permission_body">To ring the alarm at the exact time, the \'Schedule Alarms and Reminders\' permission is required.\nPlease allow it in Settings.</string>

    <!-- Notification permission pre-prompt (Android 13+). Shown before the system dialog to build trust and clarify we don\'t send ad/marketing pushes. -->
    <string name="message_notif_rationale_title">🔔 About Notification Permission</string>
    <string name="message_notif_rationale_body">WeatherWake uses notifications only for:\n\n• Ringing your alarms (lock-screen display)\n• A system notification showing an alarm is ringing\n• Explaining weather-based alarm advance\n\nWeatherWake will never send advertising, marketing, or promotional notifications.\n\nIf you decline, alarms will still ring, but notification-center display and some related features may be limited.</string>
    <string name="action_notif_rationale_proceed">Continue &amp; request permission</string>
    <string name="action_notif_rationale_later">Later</string>
    <string name="dialog_weather_notice_title">━ Settings for this alarm ━</string>
    <string name="dialog_weather_notice_body">Name : \u200B%8$s\u200B\nAlarm time : %2$s\nRepeat : %7$s\n\n90 minutes before the alarm time, the app fetches the short-term forecast *for the alarm time* from the Korea Meteorological Administration and OpenWeatherMap and cross-validates the results.</string>
    <string name="dialog_weather_notice_body_kr">Name : \u200B%8$s\u200B\nAlarm time : %2$s\nRepeat : %7$s\n\n90 minutes before the alarm time, the app fetches the short-term forecast *for the alarm time* from the Korea Meteorological Administration and OpenWeatherMap and cross-validates the results.</string>
    <string name="dialog_weather_notice_body_us">Name : \u200B%8$s\u200B\nAlarm time : %2$s\nRepeat : %7$s\n\n90 minutes before the alarm time, the app fetches the short-term forecast *for the alarm time* from the US National Weather Service (NWS) and OpenWeatherMap and cross-validates the results.</string>
    <string name="dialog_weather_notice_body_global">Name : \u200B%8$s\u200B\nAlarm time : %2$s\nRepeat : %7$s\n\n90 minutes before the alarm time, the app fetches the short-term forecast *for the alarm time* from OpenWeatherMap.</string>
    <string name="dialog_weather_notice_detail_title">Advance behavior details</string>
    <string name="dialog_weather_notice_detail_body">Based on the result:\nExample) For \'\u200B%8$s\u200B\':\n\n  • Rain detected  → rings at %3$s (%5$d min earlier)\n  • Snow detected  → rings at %4$s (%6$d min earlier)\n  • Clear/cloudy   → rings at %2$s (normal)\n\nWeather changes between %1$s and %2$s won\'t affect the alarm.</string>
    <string name="dialog_weather_notice_learn_more">Learn more</string>
    <string name="dialog_weather_notice_detail_close">Close</string>
    <string name="dialog_repeat_every_day">every day</string>
    <string name="dialog_repeat_weekdays">on weekdays (Mon–Fri)</string>
    <string name="dialog_repeat_weekends">on weekends (Sat–Sun)</string>
    <string name="dialog_repeat_once">(one-time)</string>
    <string name="dialog_weather_notice_warning">⚠ Network issues, battery optimization, or OS updates may delay or fail the weather check.\n\nFor critical schedules, please also use your phone\'s built-in alarm.</string>
    <string name="dialog_weather_notice_ok">I understand</string>
    <string name="message_battery_opt_title">🔋 Battery Optimization Exception (recommended)</string>
    <string name="message_battery_opt_body">Your alarm itself will ring on time regardless of this setting.\n\nHowever, the feature that checks the weather 90 minutes before the alarm and wakes you earlier when rain or snow is detected works more reliably with this exception. (WeatherWake checks the weather only once per alarm to keep battery use minimal.)\n\nWithout it, the weather-based early wake-up may be delayed by a few minutes.</string>
